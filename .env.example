# Public deployment URL used by the local runner.
CONVEX_URL=https://your-deployment.convex.cloud

# The same public URL is bundled into the Vite game route for published-run reads.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Shared only by the local runner and protected Convex mutations/actions.
STUDIO_INTEGRATION_TOKEN=replace-with-a-long-random-value
