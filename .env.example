# Public Pages URL used by the local runner for D1/R2 evidence writes.
CLOUDFLARE_EVIDENCE_URL=https://your-project.pages.dev

# Shared only by the local runner and protected Pages evidence endpoints.
STUDIO_INTEGRATION_TOKEN=replace-with-a-long-random-value

# Shared only by the Pages Function proxy and local runner. Never prefix this
# with VITE_; the browser must not receive it.
SOULLOOM_RUNNER_API_TOKEN=replace-with-another-long-random-value

# Optional local runner settings.
SOULLOOM_RUNNER_PORT=8787
SOULLOOM_HERMES_TIMEOUT_MS=30000
# Required in live Hermes mode so --safe-mode never falls back to user config.
SOULLOOM_HERMES_PROVIDER=openai-api
SOULLOOM_HERMES_MODEL=your-model
# Linux runner sandbox. Override only if Bubblewrap is installed elsewhere.
# SOULLOOM_HERMES_SANDBOX_BIN=/usr/bin/bwrap
